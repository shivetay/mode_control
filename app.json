{
  "expo": {
    "name": "Mood Tracker",
    "slug": "mood-track",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mood-tracker",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.moodtrackerdairy.app",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Aplikacja wysyła przypomnienia o zapisaniu nastroju o wybranych porach."
      }
    },
    "android": {
      "package": "com.moodtrackerdairy.app",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "com.google.android.gms.permission.AD_ID"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-sqlite",
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#8C7D70",
          "defaultChannel": "reminders",
          "sounds": []
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2144729765788406~6520232344",
          "iosAppId": "ca-app-pub-2144729765788406~3260211432"
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "ads": {
        "bottomBannerAndroid": "ca-app-pub-2144729765788406/8557226997",
        "bottomBannerIos": "ca-app-pub-2144729765788406/9487165282",
        "inlineBannerAndroid": "ca-app-pub-2144729765788406/9678736973",
        "inlineBannerIos": "ca-app-pub-2144729765788406/1608675260",
        "historyMidBannerAndroid": "ca-app-pub-2144729765788406/8365655307",
        "historyMidBannerIos": "ca-app-pub-2144729765788406/6352479876"
      },
      "router": {},
      "eas": {
        "projectId": "d37ee61f-a496-420c-b63e-041411cdb9ae"
      }
    }
  }
}
